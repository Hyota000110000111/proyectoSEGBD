# ============================================
# FARMA SEGURA - Configuración de entorno
# ============================================
# Copia este archivo como .env y edita según tu entorno

# ------------------------------------------------------------
# SEGURIDAD
# ------------------------------------------------------------
SECRET_KEY=clave-segura-aleatoria-para-desarrollo

# ------------------------------------------------------------
# BASE DE DATOS OPERATIVA (negocio)
# ------------------------------------------------------------
# Opciones por defecto (funciona en XAMPP/WAMP con root sin contraseña)
#DATABASE_OPERATIVA_URL=mysql+pymysql://root:@localhost/farmasegura_operativa
DATABASE_OPERATIVA_URL=mysql+pymysql://app_farmasegura:FarmaApp2025!@localhost/farmasegura_operativa
# Conexión a BD Seguridad
DATABASE_SEGURIDAD_URL=mysql+pymysql://app_farmasegura:FarmaApp2025!@localhost/farmasegura_seguridad

# ------------------------------------------------------------
# BASE DE DATOS DE SEGURIDAD (auditoría, logs, eventos)
# ------------------------------------------------------------
#DATABASE_SEGURIDAD_URL=mysql+pymysql://root:@localhost/farmasegura_seguridad
# ------------------------------------------------------------
# CONFIGURACIÓN DE BCRYPT (hashing de contraseñas)
# ------------------------------------------------------------
BCRYPT_LOG_ROUNDS=12

# ------------------------------------------------------------
# CONFIGURACIÓN DE SESIÓN (opcional)
# ------------------------------------------------------------
SESSION_PERMANENT=False